# Absolute path to your vault (or any subdirectory within one)
VAULT_PATH=/path/to/your/vault

# Note-taking app. Supported: obsidian (default), logseq
VAULT_APP=obsidian

# Cosine similarity threshold — notes below this score are ignored.
# Accepts a float in [0, 1] or a named level:
#   low    → 0.60  (more connections, less precise)
#   medium → 0.75  (default, balanced)
#   high   → 0.88  (fewer connections, higher precision)
SIMILARITY_THRESHOLD=medium

# Maximum number of backlinks to add per note
TOP_K=5

# Directory where the ONNX model files will be cached
MODEL_DIR=./models

# HuggingFace model identifier (Xenova ONNX exports).
# Change this to use a different sentence-transformer model.
# Note: if you switch models, clear MODEL_DIR first to avoid stale cache.
MODEL_NAME=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# Directory where per-run JSON logs are written
LOG_DIR=./logs

# Set to "true" to preview proposed links without writing to disk
# When true, the backup prompt is also skipped
DRY_RUN=false

# Comma-separated list of directories (relative to VAULT_PATH) to skip entirely.
# Useful for journals, templates, or any folder you don't want linked.
# Prefix matching: "journal" excludes vault/journal/ but not vault/project/journal/
# Leave empty (or omit) to process the entire vault.
# EXCLUDE_DIRS=journal,templates,private

# Comma-separated list of directories (relative to VAULT_PATH) to scan exclusively.
# When set, only files under these directories are processed; all others are ignored.
# EXCLUDE_DIRS is still applied afterwards, so you can narrow further within the whitelist.
# Example: scan only "projects/" but skip "projects/drafts/":
#   INCLUDE_DIRS=projects
#   EXCLUDE_DIRS=projects/drafts
# Leave empty (or omit) to process the entire vault (minus any EXCLUDE_DIRS).
# INCLUDE_DIRS=projects,areas
